{
  "manifest_version": 3,
  "name": "Tab Reload Timer — Auto Refresh Pages",
  "short_name": "Tab Reload Timer",
  "version": "1.1.0",
  "description": "Auto-reload tabs on a custom interval. Per-tab timers with random variation, badge countdown, and session restore.",
  "permissions": ["tabs", "alarms", "storage", "contextMenus", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-reload": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Start or stop reloading the current tab"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tab Reload Timer",
    "default_icon": {
      "16": "icons/idle-16.png",
      "32": "icons/idle-32.png",
      "48": "icons/idle-48.png",
      "128": "icons/idle-128.png"
    }
  },
  "icons": {
    "16": "icons/idle-16.png",
    "32": "icons/idle-32.png",
    "48": "icons/idle-48.png",
    "128": "icons/idle-128.png"
  }
}
